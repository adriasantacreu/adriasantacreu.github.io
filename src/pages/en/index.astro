---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard";
import StackCard from "@components/StackCard.astro";
import { SITE, SOCIALS } from "@consts";
import TwinklingStars from "@components/TwinklingStars.astro";
import MeteorShower from "@components/MeteorShower.astro";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft && project.data.lang === "en")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const stack = [
  { text: "Python", icon: "python", href: "https://www.python.org" },
  { text: "n8n", icon: "n8n", href: "https://n8n.io" },
  { text: "LaTeX", icon: "latex", href: "https://www.latex-project.org" },
  {
    text: "AppScript",
    icon: "javascript",
    href: "https://developers.google.com/apps-script",
  },
  { text: "Astro", icon: "astro", href: "https://astro.build" },
];
---

<PageLayout title="Home" description={SITE.DESCRIPTION} hideStarfield={true}>
  <div class="absolute inset-0 block dark:hidden">
    <div id="particles1" class="fixed inset-0"></div>
    <div id="particles2" class="fixed inset-0"></div>
    <div id="particles3" class="fixed inset-0"></div>
  </div>
  <div class="absolute inset-0 bg-black hidden dark:block">
    <div id="stars1" class="fixed inset-0"></div>
    <div id="stars2" class="fixed inset-0"></div>
    <div id="stars3" class="fixed inset-0"></div>
  </div>
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars />
      <MeteorShower />
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>

  <section class="relative h-screen w-full">
    <div
      id="planetcont"
      class="animate absolute inset-0 top-1/4 overflow-hidden"
    >
      <div
        id="crescent"
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[250vw] min-h-[100vh] aspect-square rounded-full p-[1px] bg-gradient-to-b from-black/25 dark:from-white/75 from-0% to-transparent to-5%"
      >
        <div
          id="planet"
          class="w-full h-full bg-white dark:bg-black rounded-full p-[1px] overflow-hidden flex justify-center"
        >
          <div
            id="blur"
            class="w-full h-20 rounded-full bg-neutral-900/25 dark:bg-white/25 blur-3xl"
          >
          </div>
        </div>
      </div>
    </div>
    <div
      class="animate absolute h-full w-full flex items-center justify-center"
    >
      <div class="relative w-full h-full flex items-center justify-center">
        <div class="p-5 text-center">
          <p
            class="animated text-2xl md:text-3xl lg:text-4xl font-bold uppercase text-black dark:text-white"
          >
            {SITE.AUTHOR}
          </p>
          <p class="animated text-sm md:text-base lg:text-lg opacity-75 tracking-wide">
            Data Science &nbsp;·&nbsp; Automations &nbsp;·&nbsp; Physics &nbsp;·&nbsp; Teaching
          </p>
          <div
            id="ctaButtons"
            class="animated flex flex-wrap gap-4 justify-center mt-5"
          >
            <a
              href="/en/projects"
              class="py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend"
            >
              View Projects
            </a>
            <a
              href="https://github.com/adriasantacreu"
              target="_blank"
              class="py-2 px-4 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend flex items-center gap-2"
            >
              <svg viewBox="0 0 16 16" class="size-4 fill-current flex-shrink-0"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
  <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">
    <section class="animate">
      <article>
        <p>
          I'm a physicist and programmer, specialised in new technologies and artificial intelligence. I'm currently completing a Master's degree in <b>Data Science</b> to consolidate my analytical and programming skills.
        </p>
        <p>
          I have experience solving problems and optimising processes through technology, which is one of the parts I enjoy most about my work. I'm looking for new challenges where I can combine my scientific background with software development.
        </p>
        <p>
          I'm passionate about automation and building tools that improve productivity, using Python, Apps Script and AI models.
        </p>
      </article>
    </section>

    <section class="animate">
      <div class="space-y-4">
        <p class="font-semibold text-black dark:text-white">
          Tools &amp; Technologies
        </p>
        <div class="flex flex-wrap items-center gap-2 mt-5">
          {
            stack.map((item) => (
              <StackCard text={item.text} icon={item.icon} href={item.href} />
            ))
          }
        </div>
      </div>
    </section>

    <section class="animate">
      <div class="space-y-4">
        <div class="flex justify-between">
          <p class="font-semibold text-black dark:text-white">
            Recent Projects
          </p>
          <a
            href="/en/projects"
            class="w-fit group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend"
          >
            <span
              class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend"
            >
              All projects
            </span>
          </a>
        </div>
        <ul class="space-y-4">
          {
            projects.map((project) => (
              <li>
                <ArrowCard entry={project} href={`/en/projects/${project.slug.replace(/\/index\.[a-z.]+$/, '')}`} />
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="animate">
      <div>
        <p class="font-semibold text-black dark:text-white">Get in touch</p>
        <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
          {
            SOCIALS.map((social) => (
              <>
                <div class="col-span-1 flex items-center gap-1">
                  <span class="whitespace-nowrap truncate">{social.NAME}</span>
                </div>
                <div class="col-span-3 truncate">
                  <a
                    href={social.HREF}
                    target="_blank"
                    class="w-fit group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend"
                  >
                    <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                      {social.TEXT}
                    </span>
                  </a>
                </div>
              </>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</PageLayout>
