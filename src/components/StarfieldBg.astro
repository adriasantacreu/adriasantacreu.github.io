---
/**
 * StarfieldBg.astro
 * Fons d'estels subtil per a totes les pàgines (dark mode only).
 * Generat al build time: sense JS en runtime, sense impacte de rendiment.
 */

function randomStars(n: number, opacity: number): string {
  const shadows: string[] = []
  for (let i = 0; i < n; i++) {
    const x = Math.floor(Math.random() * 2560)
    const y = Math.floor(Math.random() * 2560)
    shadows.push(`${x}px ${y}px rgba(255,255,255,${opacity})`)
  }
  return shadows.join(", ")
}

const starsSmall  = randomStars(350, 0.55)
const starsMedium = randomStars(120, 0.70)
const starsLarge  = randomStars(40,  0.85)
---

<div id="sfbg-small"  aria-hidden="true"></div>
<div id="sfbg-medium" aria-hidden="true"></div>
<div id="sfbg-large"  aria-hidden="true"></div>

<style is:global>
  #sfbg-small,
  #sfbg-medium,
  #sfbg-large {
    display: none;
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  html.dark #sfbg-small {
    display: block;
    width: 1px;
    height: 1px;
    opacity: 0.4;
  }

  html.dark #sfbg-medium {
    display: block;
    width: 1px;
    height: 1px;
    opacity: 0.5;
  }

  html.dark #sfbg-large {
    display: block;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    opacity: 0.6;
  }
</style>

<script define:vars={{ starsSmall, starsMedium, starsLarge }}>
  function applyStars() {
    const small  = document.getElementById("sfbg-small")
    const medium = document.getElementById("sfbg-medium")
    const large  = document.getElementById("sfbg-large")
    if (small)  small.style.boxShadow  = starsSmall
    if (medium) medium.style.boxShadow = starsMedium
    if (large)  large.style.boxShadow  = starsLarge
  }
  applyStars()
  document.addEventListener("astro:after-swap", applyStars)
</script>
