---
/**
 * StarfieldBg.astro — fons d'estels subtil (dark mode only, totes les pàgines)
 * Tot via JS: evita el tree-shaking d'Astro en styles globals condicionals.
 */

function randomStars(n: number, opacity: number): string {
  const s: string[] = []
  for (let i = 0; i < n; i++) {
    s.push(`${Math.floor(Math.random()*2560)}px ${Math.floor(Math.random()*2560)}px rgba(255,255,255,${opacity})`)
  }
  return s.join(",")
}

const small  = randomStars(350, 0.5)
const medium = randomStars(100, 0.65)
const large  = randomStars(35,  0.8)
---

<script define:vars={{ small, medium, large }}>
  function injectStarfield() {
    // Elimina instàncies anteriors (navegació SPA)
    ["sfbg-s","sfbg-m","sfbg-l","sfbg-style"].forEach(id => {
      document.getElementById(id)?.remove()
    })

    const style = document.createElement("style")
    style.id = "sfbg-style"
    style.textContent = `
      .sfbg {
        display: none;
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }
      html.dark .sfbg { display: block; }
    `
    document.head.appendChild(style)

    const base = "position:fixed;inset:0;pointer-events:none;z-index:0;width:1px;height:1px;"
    const make = (id, shadow, extra) => {
      const d = document.createElement("div")
      d.id = id
      d.className = "sfbg"
      d.setAttribute("aria-hidden", "true")
      d.setAttribute("style", base + "box-shadow:" + shadow + ";" + (extra||"") + ";opacity:0.4")
      document.body.appendChild(d)
    }

    make("sfbg-s", small, "")
    make("sfbg-m", medium, "opacity:0.5")
    make("sfbg-l", large, "width:2px;height:2px;border-radius:50%;opacity:0.6")
  }

  injectStarfield()
  document.addEventListener("astro:after-swap", injectStarfield)
</script>
