---
/**
 * StarfieldBg.astro — fons d'estels en dark mode
 * Lògica 100% JS: sense CSS dinàmic, sense class toggles.
 * Les estrelles s'afegeixen/eliminen del DOM segons html.dark.
 */

function randomStars(n: number, opacity: number): string {
  const s: string[] = []
  for (let i = 0; i < n; i++) {
    s.push(`${Math.floor(Math.random()*2560)}px ${Math.floor(Math.random()*2560)}px rgba(255,255,255,${opacity})`)
  }
  return s.join(",")
}

const small  = randomStars(700, 0.7)
const medium = randomStars(200, 0.85)
const large  = randomStars(50,  1.0)
---

<script define:vars={{ small, medium, large }}>
  const IDS = ["sfbg-s", "sfbg-m", "sfbg-l"]

  function isDark() {
    return document.documentElement.classList.contains("dark")
  }

  function removeStars() {
    IDS.forEach(id => document.getElementById(id)?.remove())
  }

  function addStars() {
    removeStars()

    const make = (id, shadow, size) => {
      const d = document.createElement("div")
      d.id = id
      d.setAttribute("aria-hidden", "true")
      d.setAttribute("style",
        `position:fixed;top:0;left:0;width:${size}px;height:${size}px;` +
        `pointer-events:none;z-index:1;box-shadow:${shadow}`
      )
      document.body.appendChild(d)
    }

    make("sfbg-s", small,  1)
    make("sfbg-m", medium, 1)
    make("sfbg-l", large,  2)
  }

  function syncStars() {
    if (isDark()) {
      addStars()
    } else {
      removeStars()
    }
  }

  // Reacciona al toggle dark/light sense recarregar pàgina
  new MutationObserver(syncStars).observe(
    document.documentElement,
    { attributes: true, attributeFilter: ["class"] }
  )

  syncStars()
  document.addEventListener("astro:after-swap", syncStars)
</script>
